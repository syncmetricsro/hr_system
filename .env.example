DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=replace-with-a-local-development-secret
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

DB_NAME=jober
DB_USER=jober
DB_PASSWORD=replace-with-local-db-password
DB_HOST=jober-dev-db
DB_PORT=5432

TAILWIND_BIN=/absolute/path/to/verified/tailwindcss
